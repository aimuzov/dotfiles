{
    "filesystem": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-filesystem",
        "--",
        "mcp-server-filesystem",
        "{{ .chezmoi.homeDir }}"
      ]
    },
    "git": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "pipx:mcp-server-git",
        "--",
        "mcp-server-git"
      ]
    },
    "fetch": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "pipx:mcp-server-fetch",
        "--",
        "mcp-server-fetch"
      ]
    },
    "memory": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-memory",
        "--",
        "mcp-server-memory"
      ]
    },
    "everything": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-everything",
        "--",
        "mcp-server-everything"
      ]
    },
    "sequential-thinking": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-sequential-thinking",
        "--",
        "mcp-server-sequential-thinking"
      ]
    },
    "context7": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@upstash/context7-mcp",
        "--",
        "context7-mcp"
      ]
    },
    "eslint": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@eslint/mcp",
        "--",
        "mcp"
      ]
    },
    "devtools": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:chrome-devtools-mcp",
        "--",
        "chrome-devtools-mcp"
      ]
    },
    "figma": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:figma-mcp",
        "--",
        "figma-mcp"
      ],
      "env": {
        "FIGMA_API_KEY": "{{ keepassxcAttribute "FIGMA" "TOKEN" }}"
      }
    },
    "serena": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "pipx:serena-agent",
        "--",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ],
      "env": {
        "MCP_TIMEOUT": "60000"
      }
    }
  }
