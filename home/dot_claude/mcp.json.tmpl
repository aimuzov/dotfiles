{
    "filesystem": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-filesystem",
        "--",
        "mcp-server-filesystem",
        "{{ .chezmoi.homeDir }}"
      ]
    },
    "git": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "pipx:mcp-server-git",
        "--",
        "mcp-server-git"
      ]
    },
    "fetch": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "pipx:mcp-server-fetch",
        "--",
        "mcp-server-fetch"
      ]
    },
    "memory": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-memory",
        "--",
        "mcp-server-memory"
      ]
    },
    "everything": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-everything",
        "--",
        "mcp-server-everything"
      ]
    },
    "sequential-thinking": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@modelcontextprotocol/server-sequential-thinking",
        "--",
        "mcp-server-sequential-thinking"
      ]
    },
    "eslint": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:@eslint/mcp",
        "--",
        "mcp"
      ]
    },
    "devtools": {
      "command": "{{ .miseBinPath }}",
      "args": [
        "exec",
        "npm:chrome-devtools-mcp",
        "--",
        "chrome-devtools-mcp"
      ]
    }
  }
