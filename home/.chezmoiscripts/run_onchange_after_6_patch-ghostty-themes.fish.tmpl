#!/usr/bin/env fish
# vi: ft=fish

# epoch-week: {{ div (now | unixEpoch) 604800 }}

{{ if (eq .chezmoi.os "darwin") -}}

set -l themes_dir $XDG_CONFIG_HOME/ghostty/themes
set -l base_url "https://raw.githubusercontent.com/catppuccin/ghostty/refs/heads/main/themes"

mkdir -p $themes_dir

curl -fsSL "$base_url/catppuccin-macchiato.conf" -o $themes_dir/catppuccin-macchiato.conf
curl -fsSL "$base_url/catppuccin-latte.conf" -o $themes_dir/catppuccin-latte.conf

sed -i '' 's/^background = .*/background = #1e2030/' $themes_dir/catppuccin-macchiato.conf
sed -i '' 's/^background = .*/background = #e6e9ef/' $themes_dir/catppuccin-latte.conf

{{ end -}}
