# -- Manual system setting --------------------------------------------------------------------------------------------
# caps_lock → left_control: System Settings → Keyboard → Keyboard Shortcuts → Modifier Keys (per keyboard)
# Stored by hidd daemon, cannot be scripted via defaults write.

# -- Layout fixes ------------------------------------------------------------------------------------------------------

0xa						|	0x32			# § => `
shift - 0xa				|	shift - 0x32	# shift - § => ~

# -- Useful fixes ------------------------------------------------------------------------------------------------------

rcmd - escape			|	0x32			# `
cmd + ctrl - space		:	true			# ban emoji >:D
cmd - h					:	true			# ban app hiding

# -- Key navigation ----------------------------------------------------------------------------------------------------

cmd + ctrl - j			|	down
cmd + ctrl - k			|	up
cmd + ctrl - h			|	left
cmd + ctrl - l			|	right

# -- F1-F12 ------------------------------------------------------------------------------------------------------------

lcmd + lctrl - 1		|	f1
lcmd + lctrl - 2		|	f2
lcmd + lctrl - 3		|	f3
lcmd + lctrl - 4		|	f4
lcmd + lctrl - 5		|	f5
lcmd + lctrl - 6		|	f6
lcmd + lctrl - 7		|	f7
lcmd + lctrl - 8		|	f8
lcmd + lctrl - 9		|	f9
lcmd + lctrl - 0		|	f10
lcmd + lctrl - 0x1b 	|	f11
lcmd + lctrl - 0x18		|	f12

rcmd - 1				|	f1
rcmd - 2				|	f2
rcmd - 3				|	f3
rcmd - 4				|	f4
rcmd - 5				|	f5
rcmd - 6				|	f6
rcmd - 7				|	f7
rcmd - 8				|	f8
rcmd - 9				|	f9
rcmd - 0				|	f10
rcmd - 0x1b				|	f11
rcmd - 0x18				|	f12

