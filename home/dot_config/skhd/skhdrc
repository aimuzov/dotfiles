# -- Spaces / focus ----------------------------------------------------------------------------------------------------

alt - 1		: @space_focus("1")
alt - 2		: @space_focus("2")
alt - 3		: @space_focus("3")
alt - 4		: @space_focus("4")
alt - 5		: @space_focus("5")
alt - 6		: @space_focus("6")
alt - 7		: @space_focus("7")
alt - 8		: @space_focus("8")
alt - 9		: @space_focus("9")
alt - 0		: @space_focus("10")
alt - 0x1B	: @space_focus("11")
alt - 0x18	: @space_focus("12")

########################################################################################################################
#### Hotkeys / modes ###################################################################################################
########################################################################################################################

# -- creating ----------------------------------------------------------------------------------------------------------

:: command @				:	@sbe_mode("command")
:: move @					:	@sbe_mode("move")
:: resize @					:	@sbe_mode("resize")
:: stack @					:	@sbe_mode("stack")
:: window @					:	@sbe_mode("window")

# -- mapping / entering to mode ----------------------------------------------------------------------------------------

cmd + ctrl - m				;	move
cmd + ctrl - q				;	command
cmd + ctrl - r				;	resize
cmd + ctrl - s				;	stack
cmd + ctrl - w				;	window

# -- mapping / reentering to mode --------------------------------------------------------------------------------------

command	< cmd + ctrl - s	;	stack
move	< cmd + ctrl - s	;	stack
resize	< cmd + ctrl - s	;	stack
window	< cmd + ctrl - s	;	stack

command	< cmd + ctrl - m	;	move
resize	< cmd + ctrl - m	;	move
stack	< cmd + ctrl - m	;	move
window	< cmd + ctrl - m	;	move

command	< cmd + ctrl - w	;	window
move	< cmd + ctrl - w	;	window
resize	< cmd + ctrl - w	;	window
stack	< cmd + ctrl - w	;	window

command	< cmd + ctrl - r	;	resize
move	< cmd + ctrl - r	;	resize
stack	< cmd + ctrl - r	;	resize
window	< cmd + ctrl - r	;	resize

move	< cmd + ctrl - q	;	command	
resize	< cmd + ctrl - q	;	command	
stack	< cmd + ctrl - q	;	command	
window	< cmd + ctrl - q	;	command	

# -- mapping / return to default ---------------------------------------------------------------------------------------

command	< escape			;	default	:	@sbe_mode("default")
move	< escape			;	default	:	@sbe_mode("default")
resize	< escape			;	default	:	@sbe_mode("default")
stack	< escape			;	default	:	@sbe_mode("default")
window	< escape			;	default	:	@sbe_mode("default")

command	< ctrl - 0x21		;	default	:	@sbe_mode("default")
move	< ctrl - 0x21		;	default	:	@sbe_mode("default")
resize	< ctrl - 0x21		;	default	:	@sbe_mode("default")
stack	< ctrl - 0x21		;	default	:	@sbe_mode("default")
window	< ctrl - 0x21		;	default	:	@sbe_mode("default")

# -- mapping / commands ------------------------------------------------------------------------------------------------

command	< r					:	yabai.restart
command	< q					:	pmset displaysleepnow

# -- mapping / [window] ------------------------------------------------------------------------------------------------

window < e			:	@window_toggle_equal
window < r			:	yabai.restart 
window < f			:	@window_toggle_float
window < h			:	@window_focus_left
window < j			:	@window_focus_down
window < k			:	@window_focus_up
window < l			:	@window_focus_right
window < m			:	@window_toggle_maximize_full
window < p			:	@window_toggle_maximize_parent
window < q			:	@window_close

window < shift - h	:	@window_stack_left
window < shift - j	:	@window_stack_down
window < shift - k	:	@window_stack_up
window < shift - l	:	@window_stack_right
window < shift - n	:	@window_focus_stack_right
window < shift - p	:	@window_focus_stack_left
window < shift - r	:	@window_unstack

window < ctrl - h	:	@window_resize_left
window < ctrl - j	:	@window_resize_down
window < ctrl - k	:	@window_resize_up
window < ctrl - l	:	@window_resize_right

# -- mapping / [resize] ------------------------------------------------------------------------------------------------

resize < h			:	@window_resize_left
resize < j			:	@window_resize_down
resize < k			:	@window_resize_up
resize < l			:	@window_resize_right

# -- mapping / [move] --------------------------------------------------------------------------------------------------

move < h			:	@window_move_left
move < j			:	@window_move_down
move < k			:	@window_move_up
move < l			:	@window_move_right
move < r			:	@window_layout_rotate
move < x			:	@window_layout_mirror_x
move < y			:	@window_layout_mirror_y

# -- mapping / [stack] -------------------------------------------------------------------------------------------------

stack < h			:	@window_stack_left
stack < j			:	@window_stack_down
stack < k			:	@window_stack_up
stack < l			:	@window_stack_right
stack < n			:	@window_focus_stack_right
stack < p			:	@window_focus_stack_left
stack < r			:	@window_unstack
