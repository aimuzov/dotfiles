#!/usr/bin/env bash
set -euo pipefail

# MCP-серверы из общего шаблона (тот же используется для ~/.claude/mcp.json).
mcp_json=$(cat <<'CHEZMOI_MCP_EOF'
{{ includeTemplate "dot_claude/mcp.json.tmpl" . | trim }}
CHEZMOI_MCP_EOF
)

MISE="{{ .miseBinPath }}"

# Текущее содержимое целевого файла; при первом apply stdin пустой.
input=$(cat)
if [[ -z "$input" ]] || ! printf '%s' "$input" | "$MISE" exec -- jq empty >/dev/null 2>&1; then
  input='{}'
fi

# Перезаписываем только наши поля, не трогая runtime-state приложения
# (epitaxyPrefs, remoteToolsDeviceName и т.п.).
printf '%s' "$input" | "$MISE" exec -- jq \
  --argjson mcp "$mcp_json" '
    .mcpServers = $mcp
    | .preferences //= {}
    | .preferences.menuBarEnabled = true
    | .preferences.quickEntryShortcut = "off"
    | .preferences.quickEntryDictationShortcut = "off"
    | .preferences.coworkScheduledTasksEnabled = true
    | .preferences.ccdScheduledTasksEnabled = true
    | .preferences.sidebarMode = "epitaxy"
    | .preferences.coworkWebSearchEnabled = true
    | .preferences.keepAwakeEnabled = true
  '
