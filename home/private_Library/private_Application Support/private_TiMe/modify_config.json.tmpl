#!/usr/bin/env bash
set -euo pipefail

# The entire config.json is owned by dotfiles and defined here (the fields below win).
# Exception — "webappVersion": TiMe updates it itself when the web app
# auto-updates, so this field is taken from the current target file. That way chezmoi
# does not show a change just because the web app version changed.
ours=$(cat <<'CHEZMOI_TIME_EOF'
{
  "version": 3,
  "teams": [
    {
      "name": "time.r1.team",
      "url": "https://time.r1.team",
      "order": 0,
      "tabs": [
        {
          "name": "TAB_MESSAGING",
          "order": 0,
          "isOpen": true
        },
        {
          "name": "TAB_FOCALBOARD",
          "order": 1
        },
        {
          "name": "TAB_PLAYBOOKS",
          "order": 2
        }
      ],
      "lastActiveTab": 0
    }
  ],
  "showTrayIcon": false,
  "trayIconTheme": "use_system",
  "minimizeToTray": true,
  "notifications": {
    "flashWindow": 2,
    "bounceIcon": true,
    "bounceIconType": "informational"
  },
  "showUnreadBadge": true,
  "useSpellChecker": true,
  "autostart": true,
  "hideOnStart": false,
  "spellCheckerLocales": [],
  "darkMode": false,
  "lastActiveTeam": 1,
  "downloadLocation": "{{ .chezmoi.homeDir }}/temp/time",
  "startInFullscreen": false,
  "logLevel": "error",
  "autoCheckForUpdates": true,
  "enableGPUAcceleration": true,
  "webappVersion": "v6.58.2"
}
CHEZMOI_TIME_EOF
)

MISE="{{ .miseBinPath }}"

# Current content of the target file; on the first apply stdin is empty.
input=$(cat)
if [[ -z "$input" ]] || ! printf '%s' "$input" | "$MISE" exec -- jq empty >/dev/null 2>&1; then
  input='{}'
fi

# $ours defines the whole file, but webappVersion is taken from the current file
# (written by TiMe), if present. We print the result without a trailing newline —
# TiMe writes config.json without one, otherwise chezmoi would show a perpetual change.
result=$(printf '%s' "$input" | "$MISE" exec -- jq --argjson ours "$ours" \
  '$ours + (if has("webappVersion") then {webappVersion} else {} end)')
printf '%s' "$result"
